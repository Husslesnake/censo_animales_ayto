# Copia este archivo a `.env` y ajusta los valores.
# `.env` está en .gitignore; NUNCA lo commitees con contraseñas reales.

# Contraseña del usuario root de MariaDB (usada por el contenedor mariadb,
# phpmyadmin y la API). Debe tener al menos 12 caracteres en producción.
DB_ROOT_PASSWORD=change-me

# Nombre de la base de datos (por defecto: censo_animales)
DB_NAME=censo_animales
